{
  "name": "bridge-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/bridge-sdk/src",
  "projectType": "library",
  "tags": ["lib", "sdk"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "bun run build", "cwd": "packages/bridge-sdk" }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": { "command": "bun run test --coverage", "cwd": "packages/bridge-sdk" }
    }
  }
}
