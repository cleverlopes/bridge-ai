{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api",
  "projectType": "application",
  "tags": ["app", "api"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/api",
        "main": "apps/api/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "webpackConfig": "apps/api/webpack.config.js",
        "optimization": false,
        "outputHashing": "none"
      },
      "configurations": {
        "development": {
          "optimization": false
        },
        "production": {
          "optimization": true,
          "fileReplacements": []
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "api:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/api/**/*.ts"]
      }
    },
    "typeorm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --transpile-only -r tsconfig-paths/register --project apps/api/tsconfig.migrations.json ./node_modules/typeorm/cli.js"
      }
    },
    "typeorm:migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --transpile-only -r tsconfig-paths/register --project apps/api/tsconfig.migrations.json ./node_modules/typeorm/cli.js migration:generate -d packages/nest-core/src/persistence/data-source.ts"
      }
    },
    "typeorm:migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --transpile-only -r tsconfig-paths/register --project apps/api/tsconfig.migrations.json ./node_modules/typeorm/cli.js migration:run -d packages/nest-core/src/persistence/data-source.ts"
      }
    },
    "typeorm:migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --transpile-only -r tsconfig-paths/register --project apps/api/tsconfig.migrations.json ./node_modules/typeorm/cli.js migration:revert -d packages/nest-core/src/persistence/data-source.ts"
      }
    }
  }
}
